{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/prompt-contract.schema.json",
  "title": "Prompt Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "kind"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["orchestrator", "agent", "skill", "prompt", "workflow"]
    },
    "description": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/valueSpec"
      },
      "default": []
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/valueSpec"
      },
      "default": []
    },
    "reads": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "writes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "allowedTools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "completion": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "handoffs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/handoff"
      },
      "default": []
    }
  },
  "$defs": {
    "valueSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "expectedOutput": {
          "type": "string"
        }
      }
    }
  }
}
